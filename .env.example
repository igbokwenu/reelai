# QwenCloud
DASHSCOPE_API_KEY=placeholder-qwencloud-api-key

# App
PUBLIC_APP_URL=http://localhost:3000

# Password-protected Docker gateway. Generate the hash with:
# docker run --rm -it caddy:2.11.4-alpine caddy hash-password
REELAI_SITE_ADDRESS=http://localhost
REELAI_BASIC_AUTH_USER=replace-with-judge-username
REELAI_BASIC_AUTH_HASH='replace-with-caddy-password-hash'

# Database
DATABASE_URL=postgresql://placeholder-user:placeholder-password@localhost:5432/reelai

# Alibaba Cloud OSS
OSS_REGION=oss-region
OSS_BUCKET=placeholder-oss-bucket
OSS_ACCESS_KEY_ID=placeholder-oss-access-key-id
OSS_ACCESS_KEY_SECRET=placeholder-oss-access-key-secret

# Optional
QWEN_I2V_MODEL=wan2.7-i2v
QWEN_VIDEO_RESOLUTION=720P
REDIS_URL=
SENTRY_DSN=
